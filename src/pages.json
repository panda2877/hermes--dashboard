{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    },
    {
      "path": "pages/dashboard/dashboard",
      "style": {
        "navigationBarTitleText": "统计看板",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    },
    {
      "path": "pages/kanban/kanban",
      "style": {
        "navigationBarTitleText": "任务看板",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    },
    {
      "path": "pages/agents/agents",
      "style": {
        "navigationBarTitleText": "Agent",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    },
    {
      "path": "pages/repo/repo",
      "style": {
        "navigationBarTitleText": "仓库",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    },
    {
      "path": "pages/life/life",
      "style": {
        "navigationBarTitleText": "生活",
        "navigationStyle": "custom",
        "backgroundColor": "#08090a"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarBackgroundColor": "#0f1011",
    "backgroundColor": "#08090a"
  },
  "tabBar": {
    "color": "#8a8f98",
    "selectedColor": "#5e6ad2",
    "backgroundColor": "#0f1011",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/dashboard/dashboard",
        "text": "统计",
        "iconPath": "static/icons/dashboard.svg",
        "selectedIconPath": "static/icons/dashboard-active.svg"
      },
      {
        "pagePath": "pages/kanban/kanban",
        "text": "任务",
        "iconPath": "static/icons/kanban.svg",
        "selectedIconPath": "static/icons/kanban-active.svg"
      },
      {
        "pagePath": "pages/agents/agents",
        "text": "Agent",
        "iconPath": "static/icons/agents.svg",
        "selectedIconPath": "static/icons/agents-active.svg"
      },
      {
        "pagePath": "pages/repo/repo",
        "text": "仓库",
        "iconPath": "static/icons/repo.svg",
        "selectedIconPath": "static/icons/repo-active.svg"
      },
      {
        "pagePath": "pages/life/life",
        "text": "生活",
        "iconPath": "static/icons/life.svg",
        "selectedIconPath": "static/icons/life-active.svg"
      }
    ]
  }
}
